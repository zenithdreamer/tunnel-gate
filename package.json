{
  "name": "tunnel-gate",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "biome format .",
    "format:check": "biome format .",
    "format:fix": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "start": "bun run --cwd apps/server start",
    "postinstall": "bun run --cwd apps/server db:generate"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "turbo": "^2.10.5"
  }
}