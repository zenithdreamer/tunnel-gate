{
  "name": "@tunnel-gate/server",
  "private": true,
  "type": "module",
  "exports": {
    "./app": "./src/app.ts",
    "./domain/profile-config": "./src/domain/profile-config.ts"
  },
  "scripts": {
    "dev": "prisma migrate deploy && bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "db:generate": "prisma generate",
    "db:format": "prisma format",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:validate": "prisma validate",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.3.3",
    "@elysiajs/static": "^1.3.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-auth": "^1.3.4",
    "dockerode": "^5.0.1",
    "elysia": "^1.3.5",
    "tar-stream": "^3.2.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.19",
    "@types/dockerode": "^4.0.1",
    "@types/tar-stream": "^3.1.4",
    "prisma": "^7.8.0",
    "typescript": "^5.8.3"
  }
}
