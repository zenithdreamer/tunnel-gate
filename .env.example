# Demo mode, show mock data
# DEMO=true

# PostgreSQL settings
POSTGRES_DB=tunnel_gate
POSTGRES_USER=tunnel_gate
POSTGRES_PASSWORD=replace-with-a-strong-password
DATABASE_URL=postgresql://tunnel_gate:replace-with-a-strong-password@postgres:5432/tunnel_gate?schema=public

# Application secrets.
# Generate each value with: openssl rand -hex 32
BETTER_AUTH_SECRET=replace-with-a-random-secret
PROFILE_ENCRYPTION_KEY=replace-with-a-random-key

BETTER_AUTH_URL=http://localhost:3000
OPENVPN_SERVER_HOST=localhost
OPENVPN_SERVER_PORT=1194
FORWARD_PORT_RANGE=40000-40999
